# Copia questo file in .env e compila i valori. Non committere .env.

# Obbligatorio: topic ntfy a cui sei iscritto nell'app (iPhone/Android/Mac)
NTFY_TOPIC=mio_giapponese_extreme_8000

# Opzionale: URL pubblico della tua icona per le notifiche (PNG/JPG). Lascia commentato per usare l'icona predefinita.
# ICONA_NOTIFICA_URL=https://raw.githubusercontent.com/tommasostoppani17-code/jpnotify/main/assets/icona_notifica.png

# Opzionale: per test immediato (una notifica subito, ignorando orario e intervallo)
# FORCE_INVIO=1

# Opzionale: solo per scripts/arricchisci_curiosita.py (genera curiosità con Gemini). Non serve per le notifiche normali.
# GEMINI_API_KEY=...
